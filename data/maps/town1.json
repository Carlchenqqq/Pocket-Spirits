  "npcs": [
    {
      "id": "npc_mo_bo_shi",
      "x": 10,
      "y": 6,
      "type": "professor",
      "name": "墨博士",
      "dialogs": [
        "欢迎来到精灵纪元的世界！",
        "我是墨博士，研究灵兽的学者。",
        "你今天16岁了，可以领取第一只灵兽了！",
        "来，从这三只灵兽中选择一只作为你的伙伴吧。"
      ],
      "questId": "quest_start",
      "questDesc": "前往碧波镇，找到澜汐馆主做灵师资质测试。"
    },
    {
      "id": "npc_mother",
      "x": 4,
      "y": 4,
      "type": "dialog",
      "name": "芸娘",
      "dialogs": [
        "孩子，出门在外要小心啊。",
        "记得常回来看看妈妈。",
        "路上遇到危险，先保护好自己的精灵伙伴！"
      ]
    },
    {
      "id": "villager_01",
      "x": 4,
      "y": 10,
      "type": "dialog",
      "name": "张大妈",
      "dialogs": [
        "我家小明也去当灵师了，也不知道在外面怎么样…",
        "小心路上啊。"
      ]
    },
    {
      "id": "villager_02",
      "x": 16,
      "y": 10,
      "type": "dialog",
      "name": "小明的小伙伴",
      "dialogs": [
        "听说碧波镇那边最近有怪事发生！",
        "往东走就能到青叶野外了。",
        "小心路上的训练师！"
      ]
    },
    {
      "id": "villager_03",
      "x": 7,
      "y": 12,
      "type": "dialog",
      "name": "钓鱼大爷",
      "dialogs": [
        "这河里的鱼越来越少了…",
        "年轻人，去外面闯荡吧。"
      ]
    },
    {
      "id": "npc_father",
      "x": 6,
      "y": 5,
      "type": "dialog",
      "name": "云远",
      "dialogs": [
        "孩子，你终于长大了。",
        "拿着这个灵图仪，它能记录你遇到的每一只灵兽。",
        "还有这本灵师手册，里面记载了灵师的基础知识。",
        "去墨博士那里领取你的第一只灵兽吧。",
        "路上小心，爸爸等你回来。"
      ]
    }
  ],
